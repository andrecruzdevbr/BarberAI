# Copie para .env e ajuste os valores antes de subir com Docker ou em produção.
# Nunca commite o arquivo .env real.

APP_NAME=BarberAI API
APP_ENV=development
APP_DEBUG=true

API_HOST=0.0.0.0
API_PORT=8000

# Local (backend fora do Docker)
DATABASE_URL=postgresql+psycopg://barberai:barberai@localhost:5432/barberai

# Docker sobrescreve via docker-compose.yml:
# DATABASE_URL=postgresql+psycopg://barberai:barberai@postgres:5432/barberai

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# JWT — gere uma chave forte para desenvolvimento local (ex.: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET_KEY=change-me-generate-a-strong-local-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
